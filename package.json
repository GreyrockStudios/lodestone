{
  "name": "lodestone",
  "version": "0.1.0",
  "description": "Lodestone \u2014 standalone agent engine with memory, self-improvement, and proactivity",
  "type": "module",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GreyrockStudios/lodestone.git"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "memory",
    "self-improvement",
    "proactive",
    "wiki",
    "vector-db",
    "autonomous",
    "chatbot",
    "rag",
    "tools",
    "framework",
    "typescript",
    "automation"
  ],
  "bin": {
    "lodestone": "./packages/cli/dist/index.js"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run clean && npm run build --workspaces",
    "start": "node packages/core/dist/main.js",
    "dev": "npm run dev --workspace=@lodestone/core",
    "test": "npm run test --workspaces --if-present",
    "test:dogfood": "npm run test:dogfood --workspace=@lodestone/core --if-present",
    "test:all": "npm run test --workspaces --if-present && npm run test:dogfood --workspace=@lodestone/core --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "rm -rf packages/*/dist"
  },
  "files": [
    "packages/core/dist",
    "packages/cli/dist",
    "templates/"
  ],
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.84",
    "@ai-sdk/openai": "^3.0.71",
    "@earendil-works/pi-tui": "^0.79.4",
    "@inquirer/prompts": "^8.5.2",
    "@inquirer/type": "^4.0.7",
    "@types/express": "^5.0.6",
    "ai": "^6.0.206",
    "better-sqlite3": "^12.11.1",
    "chalk": "^5.6.2",
    "commander": "^13.1.0",
    "express": "^5.2.1",
    "readline": "^1.3.0",
    "socket.io": "^4.8.3",
    "yaml": "^2.4.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "socket.io-client": "^4.8.3"
  },
  "author": "Greyrock Studio",
  "homepage": "https://lodestone.greyrockstudios.com",
  "bugs": {
    "url": "https://github.com/GreyrockStudios/lodestone/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
