{
  "name": "@lodestone/core",
  "version": "0.1.0",
  "description": "Lodestone agent engine \u2014 runtime core",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "npx tsx src/test/e2e-all-gaps.ts && npx tsx src/test/e2e-phase3.ts && npx tsx src/test/e2e-sprint6.ts && npx tsx src/test/e2e-compounding.ts && npx tsx src/test/e2e-phase4.ts",
    "test:dogfood": "npx tsx src/test/dogfood.ts && npx tsx src/test/dogfood2.ts && npx tsx src/test/dogfood3.ts && npx tsx src/test/dogfood4.ts",
    "test:all": "npm run test && npm run test:dogfood",
    "test:e2e": "npx tsx src/test/e2e-all-gaps.ts && npx tsx src/test/e2e-phase3.ts && npx tsx src/test/e2e-sprint6.ts && npx tsx src/test/e2e-compounding.ts",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.18.0",
    "ollama-ai-provider": "^1.2.0",
    "ai": "^6.0.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.24.0",
    "yaml": "^2.4.0",
    "chalk": "^5.3.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "glob": "^10.3.0",
    "gray-matter": "^4.0.3",
    "node-cron": "^3.0.3",
    "uuid": "^10.0.0",
    "express": "^4.21.0",
    "socket.io": "^4.8.0"
  },
  "peerDependencies": {
    "grammy": "^1.30.0",
    "discord.js": "^14.16.0"
  },
  "peerDependenciesMeta": {
    "grammy": { "optional": true },
    "discord.js": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "@types/express": "^5.0.0",
    "vitest": "^3.0.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}