# Lodestone Environment Variables
# Copy this to .env and fill in your values

# LLM Provider (uncomment the one you're using)
OLLAMA_BASE_URL=http://ollama:11434
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Which model to use
LODESTONE_MODEL=llama3.1:8b

# Optional: Telegram bot token for channel integration
# TELEGRAM_BOT_TOKEN=

# Optional: Discord bot token for channel integration
# DISCORD_BOT_TOKEN=

# Logging
LODESTONE_LOG_LEVEL=info