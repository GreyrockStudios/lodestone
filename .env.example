# Lodestone — Environment Variables

# LLM Providers (only set the ones you use)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=

# Discord (optional)
DISCORD_BOT_TOKEN=

# Dashboard auth (optional)
LODESTONE_DASHBOARD_TOKEN=

# Logging
LODESTONE_LOG_LEVEL=info